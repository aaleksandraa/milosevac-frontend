<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    RewriteRule ^robots\.txt$ - [L]
    RewriteRule ^ads\.txt$ - [L]
    RewriteRule ^sitemap\.xml$ - [L]

    # SEO XML endpoints are generated dynamically by the API application.
    RewriteRule ^sitemap-pages\.xml$ https://api.milosevac.com/sitemap-pages.xml [R=302,L]
    RewriteRule ^sitemap-posts\.xml$ https://api.milosevac.com/sitemap-posts.xml [R=302,L]
    RewriteRule ^sitemap-articles\.xml$ https://api.milosevac.com/sitemap-posts.xml [R=302,L]
    RewriteRule ^sitemap-news\.xml$ https://api.milosevac.com/sitemap-news.xml [R=302,L]
    RewriteRule ^sitemap-matches\.xml$ https://api.milosevac.com/sitemap-matches.xml [R=302,L]
    RewriteRule ^sitemap-taxonomies\.xml$ https://api.milosevac.com/sitemap-taxonomies.xml [R=302,L]

    # React SPA fallback.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [L]
</IfModule>
